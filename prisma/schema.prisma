// prisma/schema.prisma
// Fonts & Footers — Client Portal + Leads Tool

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "darwin", "darwin-arm64"]
}

// =========================
// ENUMS
// =========================

enum Role {
  CLIENT
  ADMIN
}

// The stage a client is at in the onboarding lifecycle.
// You (admin) manually advance clients through these stages.
// Each stage gates what's visible in the client portal.
enum OnboardingStage {
  REGISTERED
  AGREEMENT_PENDING
  AGREEMENT_SIGNED
  QUESTIONNAIRE_PENDING
  QUESTIONNAIRE_SUBMITTED
  ASSETS_PENDING
  ASSETS_UPLOADED
  DESIGN_SELECTION
  DESIGN_REVIEW
  SITE_LIVE
}

enum DocumentType {
  SERVICE_AGREEMENT
  DESIGN_APPROVAL
  CONTENT_REVIEW
  GO_LIVE_CONFIRMATION
  OTHER
}

enum DocumentStatus {
  PENDING_SIGNATURE
  SIGNED
  UPLOADED // For docs that don't need a signature (just for reference)
}

enum AssetLabel {
  LOGO
  PHOTO
  BRAND_GUIDE
  DESIGN_OPTION
  OTHER
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum ChangeRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DECLINED
}

enum SupportTicketStatus {
  OPEN
  CLOSED
}

enum SitemapStatus {
  DRAFT
  REVIEW
  APPROVED
}

// =========================
// LEADS TOOL — ENUMS
// =========================

enum ProductType {
  WEBSITE
  LEADS
}

enum LeadType {
  HOT
  WARM
  COLD
}

enum LeadStatus {
  NEW
  CONTACTED
  NURTURING
  SNOOZED
  WON
  DEAD
}

enum ApolloConfidence {
  HIGH
  MEDIUM
  LOW
  UNVERIFIED
}

enum ScriptFormat {
  EMAIL
  CALL
  LINKEDIN
}

enum LeadActivityType {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  SCRIPT_GENERATED
  CONTACTED
  SNOOZED
  REMINDER_SENT
  WON
  DEAD
}

enum HotLeadSource {
  FACEBOOK
  NEXTDOOR
  EVENTBRITE
}

enum WarmLeadSignalType {
  NEW_HOTEL
  CORPORATE_EVENT
  VENUE_REVIEW
  JOB_POSTING
  ENGAGEMENT_ANNOUNCEMENT
}

// =========================
// AUTH MODELS
// (mirrors your standard pattern exactly)
// =========================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  password      String?

  passwordSetToken       String?   @unique
  passwordSetTokenExpiry DateTime?

  roles Role[] @default([CLIENT])

  // One-to-one client profile (only exists if role includes CLIENT)
  clientProfile ClientProfile?

  accounts Account[]
  sessions Session[]

  // Admin actions
  documentsUploaded   Document[]       @relation("DocumentUploadedBy")
  stageChangesCreated StageChangeLog[] @relation("StageChangedBy")
  supportReplies      SupportTicket[]  @relation("SupportRepliedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@index([email])
  @@index([expires])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@index([email])
  @@index([expires])
}

// =========================
// CLIENT PROFILE
// Extended info attached to a CLIENT user
// =========================

model ClientProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business info collected at signup
  businessName String
  phone        String?
  city         String?
  state        String?
  website      String? // Their current site if they have one

  // Where they are in the onboarding process (website product)
  onboardingStage OnboardingStage @default(REGISTERED)

  // Internal admin notes (never visible to client)
  internalNotes String? @db.Text

  // Stripe customer (one per client across all products)
  stripeCustomerId     String? @unique
  // NOTE: stripeSubscriptionId is legacy — kept for backwards compat with
  // existing website webhook code. New code should query Subscription rows
  // directly. Holds the WEBSITE subscription ID only.
  stripeSubscriptionId String? @unique

  // Website product relations
  questionnaire  Questionnaire?
  documents      Document[]
  brandAssets    BrandAsset[]
  invoices       Invoice[]
  changeRequests ChangeRequest[]
  supportTickets SupportTicket[]
  stageLog       StageChangeLog[]
  sitemapPages   SitemapPage[]

  // Multi-product subscriptions (was: subscription Subscription?)
  subscriptions Subscription[]

  // Leads product relations
  leadsSettings   LeadsSettings?
  savedLeads      SavedLead[]
  outreachScripts OutreachScript[]
  leadActivities  LeadActivity[]

  // Per-client billing rates for website product
  // (admin-editable before setup fee is paid)
  setupFeeAmountCents Int     @default(50000) // $500 default
  monthlyAmountCents  Int     @default(49900) // $499 default
  setupFeePaid        Boolean @default(false)

  previewUrl String?
  liveUrl    String?

  questionnaireSkipped Boolean @default(false)
  assetsSkipped        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([onboardingStage])
}

// =========================
// STAGE CHANGE LOG
// Audit trail every time admin advances a client's stage
// =========================

model StageChangeLog {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  fromStage OnboardingStage
  toStage   OnboardingStage
  note      String?         @db.Text // Optional internal note about why

  changedById String?
  changedBy   User?   @relation("StageChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([clientProfileId])
  @@index([createdAt])
}

// =========================
// QUESTIONNAIRE
// One per client. Hard-coded questions, answers stored as JSON.
// Locked after submission.
// =========================

model Questionnaire {
  id              String        @id @default(cuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  // Structured answers keyed by question ID
  // e.g. { "business_name": "Elite Black Car", "service_areas": ["Phoenix", "Scottsdale"], ... }
  answers Json?

  // Progress — saved as they go, locked on submit
  submittedAt DateTime?
  lastSavedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// DOCUMENTS
// Admin uploads docs to client accounts.
// Clients can view, download, and sign where required.
// =========================

model Document {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  title  String
  type   DocumentType
  status DocumentStatus @default(PENDING_SIGNATURE)

  // Cloudinary URL of the document file
  fileUrl  String
  fileName String // Original filename for display

  requiresSignature Boolean @default(false)

  // Signature capture
  // We use a simple approach: checkbox consent + timestamp + IP
  // This is sufficient for internal agency agreements
  signedAt         DateTime?
  signedByIp       String?
  signatureConsent Boolean? // true = "I agree this constitutes my electronic signature"

  // Who uploaded it (admin)
  uploadedById String?
  uploadedBy   User?   @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  // Visibility control — admin can hide a doc before it's ready
  visible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientProfileId])
  @@index([type])
  @@index([status])
}

// =========================
// BRAND ASSETS
// Files uploaded BY the client
// =========================

model BrandAsset {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  label    AssetLabel
  fileName String
  fileUrl  String // Cloudinary secure_url
  fileSize Int? // bytes
  mimeType String?

  // Admin can leave a note on a specific asset (e.g. "Need higher resolution")
  adminNote String?

  selected     Boolean @default(false)
  clientNotes  String?
  templateName String?
  sourceUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientProfileId])
  @@index([label])
}

// =========================
// SUBSCRIPTION
// One row per (client × product). A client subscribed to both
// website and leads will have TWO rows here.
// Mirrors their Stripe subscription.
// =========================

model Subscription {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  // Which product this subscription is for
  productType ProductType

  stripeSubscriptionId String? @unique
  stripePriceId        String?
  stripeCustomerId     String?

  status          SubscriptionStatus @default(INACTIVE)
  planAmountCents Int                @default(0) // e.g. 49900 = $499/mo
  currency        String             @default("usd")

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  billingAnchorDate  Int? // Day of month billing hits (1–28)

  cancelledAt DateTime?
  pausedAt    DateTime?

  // Setup fee fields (relevant for WEBSITE; defaults to 0 for LEADS)
  setupFeeAmountCents Int     @default(50000)
  monthlyAmountCents  Int     @default(49900)
  setupFeePaid        Boolean @default(false)

  // 7-day trial tracking (used by LEADS product)
  trialEndsAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A client can only have ONE subscription per product type.
  @@unique([clientProfileId, productType])
  @@index([clientProfileId])
  @@index([productType])
  @@index([status])
}

// =========================
// INVOICES
// Mirrors Stripe invoices locally for display in portal
// =========================

model Invoice {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  invoiceNumber   String  @unique // e.g. "INV-2026-0001"
  stripeInvoiceId String? @unique

  amountCents Int
  currency    String @default("usd")

  status  InvoiceStatus @default(DRAFT)
  paidAt  DateTime?
  dueDate DateTime?

  // PDF from Stripe or Cloudinary
  pdfUrl String?

  // Period this invoice covers
  periodStart DateTime?
  periodEnd   DateTime?

  description String? // e.g. "Monthly subscription — March 2026"

  // Which product this invoice is for (nullable for backfill compat)
  productType ProductType?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientProfileId])
  @@index([status])
  @@index([createdAt])
  @@index([productType])
}

// =========================
// CHANGE REQUESTS
// Post-launch only. Client submits, admin manages.
// =========================

model ChangeRequest {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  title       String
  description String @db.Text

  status ChangeRequestStatus @default(PENDING)

  // Admin response / notes (internal)
  adminNotes String? @db.Text

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientProfileId])
  @@index([status])
}

// =========================
// SUPPORT TICKETS
// Simple message thread between client and admin
// =========================

model SupportTicket {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  subject String
  message String @db.Text

  status SupportTicketStatus @default(OPEN)

  // Admin reply (single reply per ticket — simple for v1)
  adminReply  String?   @db.Text
  repliedAt   DateTime?
  repliedById String?
  repliedBy   User?     @relation("SupportRepliedBy", fields: [repliedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientProfileId])
  @@index([status])
}

// =========================
// SITEMAP
// =========================

model SitemapPage {
  id              String           @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile    @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  name            String
  position        Int              @default(0)
  sections        SitemapSection[]
  parentId        String?
  parent          SitemapPage?     @relation("PageChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children        SitemapPage[]    @relation("PageChildren")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([clientProfileId])
}

model SitemapSection {
  id        String           @id @default(cuid())
  pageId    String
  page      SitemapPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title     String
  copy      String?          @db.Text
  status    SitemapStatus    @default(DRAFT)
  position  Int              @default(0)
  comments  SitemapComment[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([pageId])
}

model SitemapComment {
  id         String         @id @default(cuid())
  sectionId  String
  section    SitemapSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  authorType String
  text       String         @db.Text
  createdAt  DateTime       @default(now())

  @@index([sectionId])
}

// =========================
// LEADS — User settings
// One per ClientProfile. Drives hot/warm/eventbrite filtering
// via primary market. Cold search can override per-request.
// =========================

model LeadsSettings {
  id              String        @id @default(cuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  // Primary market — drives hot/warm/eventbrite feeds
  primaryCity        String?
  primaryState       String?
  primaryLat         Float?
  primaryLng         Float?
  serviceRadiusMiles Int     @default(50)

  // SMS notifications
  phoneNumber  String?
  smsEnabled   Boolean @default(true)
  emailEnabled Boolean @default(true)

  // Onboarding modal completion
  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// LEADS — Saved leads (user's personal pipeline)
// All three lead types live here with a discriminator column
// so the kanban can drag any type into any column.
// =========================

model SavedLead {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  // Classification
  leadType LeadType
  source   String // "google_places", "facebook", "eventbrite", etc.
  category String // "wedding_venue", "hotel", "law_firm", etc.

  // Business info (mostly cold leads)
  businessName    String?
  businessAddress String?
  businessLat     Float?
  businessLng     Float?
  businessPhone   String?
  businessWebsite String?
  googlePlaceId   String?
  rating          Float?
  reviewCount     Int?

  // Contact info (Apollo-enriched or pulled from post)
  contactName      String?
  contactTitle     String?
  contactEmail     String?
  contactPhone     String?
  contactLinkedin  String?
  apolloConfidence ApolloConfidence?

  // Hot lead fields
  sourceUrl      String?
  sourcePostText String?   @db.Text
  sourcePostDate DateTime?

  // Warm lead fields
  signalType String?
  signalData Json?

  // Pipeline state
  status          LeadStatus @default(NEW)
  notes           String?    @db.Text
  snoozeUntil     DateTime?
  lastContactedAt DateTime?
  wonAt           DateTime?
  estimatedValue  Int?

  // AI metadata
  aiScore       Int?
  aiScoreReason String? @db.Text

  outreachScripts OutreachScript[]
  activities      LeadActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientProfileId, status])
  @@index([clientProfileId, leadType])
  @@index([snoozeUntil])
  @@index([googlePlaceId])
}

// =========================
// LEADS — AI-generated outreach scripts
// One lead can have multiple (email + call + LinkedIn variants).
// =========================

model OutreachScript {
  id              String        @id @default(cuid())
  savedLeadId     String
  savedLead       SavedLead     @relation(fields: [savedLeadId], references: [id], onDelete: Cascade)
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  format  ScriptFormat
  subject String?
  body    String       @db.Text

  generatedAt DateTime  @default(now())
  editedAt    DateTime?
  usedAt      DateTime?

  @@index([savedLeadId])
  @@index([clientProfileId])
}

// =========================
// LEADS — Activity log per lead
// Audit trail for status changes, notes, contact attempts.
// =========================

model LeadActivity {
  id              String        @id @default(cuid())
  savedLeadId     String
  savedLead       SavedLead     @relation(fields: [savedLeadId], references: [id], onDelete: Cascade)
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  activityType LeadActivityType
  description  String?          @db.Text
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([savedLeadId])
  @@index([clientProfileId])
}

// =========================
// LEADS — Shared market feeds
// NOT user-scoped. Filtered in API routes by user's primary market.
// Scraped on cron, auto-expired on schedule.
// =========================

model HotLeadFeed {
  id        String        @id @default(cuid())
  source    HotLeadSource
  sourceUrl String        @unique

  // Market scoping
  marketCity  String
  marketState String?
  marketLat   Float?
  marketLng   Float?

  // Poster info (when scraped)
  posterName  String?
  posterPhone String?
  posterEmail String?

  // Post content
  postText          String?   @db.Text
  postDate          DateTime?
  serviceNeededDate DateTime?

  // AI processing
  aiSummary String? @db.Text
  aiScore   Int?

  // Lifecycle — auto-expire after 72hr
  expiresAt DateTime
  scrapedAt DateTime @default(now())

  @@index([marketCity, marketState])
  @@index([expiresAt])
}

model WarmLeadFeed {
  id           String             @id @default(cuid())
  signalType   WarmLeadSignalType
  signalSource String // "linkedin", "google_reviews", "yelp", etc.
  sourceUrl    String?

  // Business
  businessName    String?
  businessAddress String?
  businessLat     Float?
  businessLng     Float?
  businessWebsite String?

  // Signal payload
  signalSummary String? @db.Text
  signalData    Json?

  // Market scoping
  marketCity  String
  marketState String?

  // Lifecycle
  detectedAt DateTime @default(now())
  expiresAt  DateTime
  aiScore    Int?

  @@index([marketCity, marketState])
  @@index([expiresAt])
}

model EventbriteEvent {
  id           String   @id @default(cuid())
  eventbriteId String   @unique
  eventName    String
  eventDate    DateTime

  // Venue
  venueName    String?
  venueAddress String?
  venueLat     Float?
  venueLng     Float?

  // Sizing
  expectedAttendance Int?
  ticketPriceMin     Decimal?
  ticketPriceMax     Decimal?

  // Organizer (when public)
  organizerName  String?
  organizerEmail String?
  organizerPhone String?

  // Categorization & market
  category    String?
  marketCity  String
  marketState String?

  aiScore   Int?
  fetchedAt DateTime @default(now())

  @@index([marketCity, marketState])
  @@index([eventDate])
}

model NewBusiness {
  id            String @id @default(cuid())
  googlePlaceId String @unique
  businessName  String
  category      String

  address String?
  lat     Float?
  lng     Float?
  website String?
  phone   String?

  marketCity  String
  marketState String?

  firstDetectedAt DateTime @default(now())

  @@index([marketCity, marketState])
  @@index([firstDetectedAt])
}
